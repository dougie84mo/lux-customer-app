{
  "expo": {
    "name": "LUX Booking",
    "slug": "luxmirror-booking",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "luxbooking",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.theluxmirror.booking",
      "supportsTablet": true
    },
    "android": {
      "package": "com.theluxmirror.booking",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_CONTACTS",
        "android.permission.WRITE_CONTACTS"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Smart Mirror Fleet uses the camera to scan device pairing QR codes."
        }
      ],
      [
        "expo-contacts",
        {
          "contactsPermission": "LUX Mirror uses your contacts so you can quickly add salon clients."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#111111"
        }
      ],
      "expo-font",
      "expo-secure-store",
      "@sentry/react-native",
      [
        "react-native-ble-plx",
        {
          "isBackgroundEnabled": false,
          "bluetoothAlwaysPermission": "LUX Mirror uses Bluetooth to set up and pair new mirrors over the air."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false,
      "reactCompiler": true
    },
    "extra": {
      "router": {}
    },
    "owner": "jdfan",
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
