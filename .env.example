# ============================================================================
# Expo client env (app/.env)
# ----------------------------------------------------------------------------
# Loaded into the app at runtime. Anything prefixed EXPO_PUBLIC_ SHIPS TO THE
# CLIENT — never put a secret here.
# ============================================================================
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Sentry crash/error reporting. The DSN is a client-side public value (safe to
# ship). Leave blank to keep Sentry wired-but-dark; set it to start reporting.
# Build-time source-map upload additionally needs SENTRY_ORG / SENTRY_PROJECT /
# SENTRY_AUTH_TOKEN in the EAS build env (NOT here — the auth token is a secret).
EXPO_PUBLIC_SENTRY_DSN=

# ============================================================================
# Supabase Edge Function secrets  —  REFERENCE ONLY, do NOT load via Expo.
# ----------------------------------------------------------------------------
# These are NOT read by the app. They live as Supabase Function secrets and
# are set with the CLI, e.g.:
#   npx supabase secrets set SMTP_HOST=... SMTP_PORT=465 SMTP_USER=... \
#       SMTP_PASS=... SMTP_FROM="LUX Mirror <noreply@mail.yourdomain.com>"
# Listed here so there's one place that documents what must be configured.
# ============================================================================

# --- SMTP (transactional email sender) --------------------------------------
# Use your DEDICATED email-sending domain's SMTP — independent of the Hostinger
# mailbox Supabase Auth uses. Host/port/credentials come from that provider.
#   - Port 465 = implicit TLS (the _shared/email.ts sender assumes 465 = TLS).
#   - Port 587 would be STARTTLS (set SMTP_PORT=587 and the sender adapts).
#   - SMTP_FROM must be an address on a domain you've verified (SPF/DKIM) at
#     that provider, or mail will be junked/blocked.
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=465
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SMTP_FROM=LUX Mirror <noreply@mail.yourdomain.com>

# --- Cron / trigger shared secret -------------------------------------------
# A long random string. Gates the cron- and trigger-invoked functions
# (send-trial-warnings, send-device-offline-alerts, notify-booking-request).
# Set the SAME value here AND in Supabase Vault as `cron_secret` (see the
# migration headers for the Vault commands).
CRON_SECRET=generate-a-long-random-string

# --- Stripe (server side; already set for start-checkout) -------------------
# STRIPE_SECRET_KEY is reused by customer-portal + cancel-subscription.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Price IDs read at runtime by start-checkout (one per plan × period):
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_STARTER_ANNUAL=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_ANNUAL=price_...
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_...
STRIPE_PRICE_ENTERPRISE_ANNUAL=price_...
